{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "postgres":"Server=127.0.0.1;Port=5432;Database=ContextCareDb;User ID=postgres;Password=db@123;"
  },
  "AllowedHosts": "*",
  "openTelemetry": {
    "endpoint": "http://localhost:4317"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Enrichers.Thread",
      "Serilog.Sinks.OpenTelemetry"
    ],
    "MinimumLevel": "Debug",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "RestrictedToMinimumLevel": "Information",
          "outputTemplate": "[{Timestamp:o}] [{Level:u3}] [{ThreadId}] {Message:lj} {Properties}{NewLine}{Exception}"
        }
      },
      {
        "Name": "OpenTelemetry"
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithThreadId"
    ]
  }
}